{
  "name": "openclaw-gui",
  "version": "1.0.23",
  "description": "OpenClaw cross-platform GUI assistant for pnpm-based install and upgrade",
  "repository": {
    "type": "git",
    "url": "https://github.com/chsword/openclaw-install-cn.git"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test src/__tests__/config.test.js src/__tests__/platform.test.js src/__tests__/logger.test.js src/__tests__/registry.test.js src/__tests__/runtime.test.js",
    "build": "electron-builder --win",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "openclaw",
    "assistant",
    "electron",
    "windows",
    "macos",
    "linux"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "ai.openclaw.installer",
    "productName": "OpenClaw Assistant",
    "copyright": "Copyright © 2025",
    "icon": "assets/icon.png",
    "artifactName": "${name}-${version}-${platform}-${arch}.${ext}",
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${name}-setup-${version}-${arch}.${ext}"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "!src/**/__tests__/**"
    ]
  }
}
