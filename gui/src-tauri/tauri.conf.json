{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Assistant",
  "version": "1.0.23",
  "identifier": "ai.openclaw.installer",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenClaw 安装助手",
        "width": 720,
        "height": 520,
        "minWidth": 720,
        "minHeight": 520,
        "maxHeight": 920,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/icon.png",
      "../assets/icon.ico",
      "../assets/icon.icns"
    ],
    "createUpdaterArtifacts": false,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "../assets/icon.ico"
      }
    }
  }
}
